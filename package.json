{
	"name": "markdown-it-mathjax3",
	"type": "module",
	"version": "4.4.0",
	"license": "AGPL-3.0-only",
	"main": "dist/main.js",
	"scripts": {
		"upd": "pnpm up --latest",
		"make": "pnpm up && pnpm test && pnpm build",
		"test": "tsc --noemit",
		"build": "tsc -d && prettier --ignore-path -w dist/"
	},
	"dependencies": {
		"@mathjax/src": "^4.1.2",
		"juice": "^12.1.1"
	},
	"devDependencies": {
		"markdown-it": "^14.2.0",
		"prettier": "^3.8.4",
		"typescript": "^6.0.3"
	},
	"optionalDependencies": {
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^26.0.1"
	},
	"pnpm": {
		"overrides": {
			"encoding-sniffer": "*"
		},
		"packageExtensions": {
			"@mathjax/mathjax-newcm-font": {
				"peerDependencies": {
					"@mathjax/src": "*"
				}
			}
		}
	}
}
